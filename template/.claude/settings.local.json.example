{
  "_comment_top": "Copy to .claude/settings.local.json (gitignore it). Two load-bearing fields: defaultMode (bypass ALL tool prompts) + additionalDirectories (pre-trust the dirs autonomy will touch). The deny list is defense-in-depth — hard-blocks destructive ops at the harness layer even if a sub-agent prompt-level halt fails.",

  "permissions": {
    "defaultMode": "bypassPermissions",

    "_comment_additional_directories": "Pre-trust subdirectories autonomy will create or write to. Without this, every NEW directory triggers a per-session prompt. List your project's spec/source/test/runs paths.",
    "additionalDirectories": [
      "<PROJECT_ROOT>",
      "<PROJECT_ROOT>/<SPEC_DIR_ROOT>",
      "<PROJECT_ROOT>/<SOURCE_DIR>",
      "<PROJECT_ROOT>/tests",
      "<PROJECT_ROOT>/scripts",
      "<PROJECT_ROOT>/docs",
      "<PROJECT_ROOT>/runs",
      "<PROJECT_ROOT>/.claude",
      "<PROJECT_ROOT>/.github",
      "<USER_HOME>/.claude/projects/<MEMORY_PATH_HASH>/memory"
    ],

    "_comment_allow": "Broad allow patterns so the autonomy team doesn't prompt per command. Bypass mode covers most of these but the explicit list is defensive against future Claude Code versions tightening behavior.",
    "allow": [
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "Bash(git *)",
      "Bash(uv *)",
      "Bash(uvx *)",
      "Bash(make *)",
      "Bash(bash *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(test *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(rm runs/*)",
      "Bash(rm -rf /tmp/*)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(tr *)",
      "Bash(curl *)",
      "Bash(unzip *)",
      "Bash(tar *)",
      "Bash(pwd *)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(claude *)",
      "Bash(sha256sum *)",
      "Bash(docker info *)",
      "Bash(docker compose *)",
      "Bash(pip show *)",
      "Bash(kill *)",
      "Bash(ps *)"
    ],

    "_comment_deny": "Defense-in-depth. These ops MUST NEVER run from the autonomy loop. If a sub-agent ever attempts one, the harness blocks before the prompt rules even fire. Customize the branch names (<MAIN_BRANCH>) and release commands (<RELEASE_COMMAND>) to your project's reality.",
    "deny": [
      "Bash(git push * <MAIN_BRANCH>*)",
      "Bash(git push origin <MAIN_BRANCH>)",
      "Bash(git push origin HEAD:<MAIN_BRANCH>)",
      "Bash(git push -f origin <MAIN_BRANCH>*)",
      "Bash(git push --force origin <MAIN_BRANCH>*)",
      "Bash(git push --force-with-lease origin <MAIN_BRANCH>*)",
      "Bash(git merge * <MAIN_BRANCH>*)",
      "Bash(git merge <MAIN_BRANCH> *)",
      "Bash(git rebase <MAIN_BRANCH> *)",
      "Bash(git rebase * <MAIN_BRANCH>*)",
      "Bash(git checkout <MAIN_BRANCH>)",
      "Bash(git switch <MAIN_BRANCH>)",
      "Bash(git reset --hard *)",
      "Bash(git tag *)",
      "Bash(<RELEASE_COMMAND> *)",
      "Bash(<RELEASE_COMMAND>)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf /home/*)",
      "Bash(rm -rf .git*)",
      "Bash(rm -rf <SPEC_DIR_ROOT>*)",
      "Bash(rm -rf <SOURCE_DIR>*)",
      "Bash(rm -rf tests*)",
      "Bash(rm -rf .claude*)"
    ]
  }
}
