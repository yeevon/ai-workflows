# .env.example — ai-workflows runtime configuration
#
# Copy this file to `.env` in the directory you run `aiw` / `aiw-mcp`
# from, fill in the values you use, and keep the `.env` out of git
# (the repo's `.gitignore` already covers it).
#
# `aiw` + `aiw-mcp` auto-load `.env` from the current working directory
# at startup (0.1.1 patch). A shell-exported variable always wins over
# the `.env` value — right precedence for CI pipelines and one-off
# inline overrides (`GEMINI_API_KEY=x aiw run ...`).
#
# -----------------------------------------------------------------------------
# Required for most workflows
# -----------------------------------------------------------------------------

# Gemini API key — used by any workflow tier that routes through LiteLLM
# with a `gemini/*` model. Get one at https://aistudio.google.com/apikey.
# Required for the shipped `planner` and `slice_refactor` workflows when
# their LiteLLM-routed tiers are active.
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Optional — set only if you need a non-default value
# -----------------------------------------------------------------------------

# Ollama base URL. Default is `http://localhost:11434`. Set this only
# if your Ollama daemon listens elsewhere (a LAN host, a non-default
# port, a Docker-mapped port).
# OLLAMA_BASE_URL=http://localhost:11434

# Path override for the run-registry SQLite database. Default is
# `~/.ai-workflows/storage.sqlite3`.
# AIW_STORAGE_DB=/tmp/ai-workflows-storage.sqlite3

# Path override for the LangGraph checkpoint SQLite database. Default
# is `~/.ai-workflows/checkpoint.sqlite3`. Kept separate from the
# storage DB so a corrupt checkpoint cannot take down run history
# (KDR-009).
# AIW_CHECKPOINT_DB=/tmp/ai-workflows-checkpoint.sqlite3

# Structlog level for library-style imports. The CLI/MCP entry points
# already call `configure_logging(level="INFO")` explicitly. Defaults
# to INFO if unset.
# AIW_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Claude Code tier (no API key here — installs separately)
# -----------------------------------------------------------------------------
# If a workflow tier routes to the `claude` CLI (opus / sonnet / haiku),
# install + authenticate the CLI separately per Anthropic's setup docs:
# https://docs.claude.com/en/docs/claude-code/setup
#
# ai-workflows never reads `ANTHROPIC_API_KEY` and never imports the
# `anthropic` SDK — Claude access is OAuth-only through the CLI
# subprocess (KDR-003). Do not add an ANTHROPIC_API_KEY line here.

# -----------------------------------------------------------------------------
# Testing / development (rarely set by end users)
# -----------------------------------------------------------------------------

# Enable end-to-end tests that shell out to live providers.
# AIW_E2E=1

# Enable live-mode eval replay (double-gated by AIW_E2E too).
# AIW_EVAL_LIVE=1

# Eval fixtures root. Default is `evals/` under the repo/install root.
# AIW_EVALS_ROOT=./evals

# Capture dataset name when `aiw eval capture --dataset ...` is not
# passed explicitly. Normally left unset.
# AIW_CAPTURE_EVALS=my-dataset
